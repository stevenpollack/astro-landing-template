# build output
dist/
# generated types
.astro/
# wrangler build artifacts
.wrangler/
# Alchemy local IaC state (kept on your machine for idempotent re-runs; not used by CI)
.alchemy/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production
.env.local
# Cloudflare local secrets (server runtime)
.dev.vars
# Turnstile keys bridged from Alchemy to the bootstrap (contains the secret)
.turnstile.json

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# playwright
test-results/
playwright-report/
