---
/*
 * Placeholder photo frame. Swap for a real <img> once you have photography
 * (replace the markup inside .photo, keep the class for sizing/shadow).
 */
interface Props {
  label: string;
  ratio?: string;
}
const { label, ratio = "4 / 5" } = Astro.props;
---

<div class="photo" style={`--ratio:${ratio}`} role="img" aria-label={`Placeholder: ${label}`}>
  <span class="photo-label">{label}</span>
  <slot />
</div>

<style>
  .photo {
    position: relative;
    aspect-ratio: var(--ratio);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    overflow: hidden;
    display: grid;
    place-items: center;
    box-shadow: var(--shadow-md);
    background: repeating-linear-gradient(
      135deg,
      var(--color-primary-wash) 0 14px,
      color-mix(in oklab, var(--color-primary-wash) 55%, var(--color-bg)) 14px 28px
    );
  }
  .photo-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-soft);
    background: color-mix(in oklab, var(--color-surface) 78%, transparent);
    padding: 7px 14px;
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-border);
    text-align: center;
    max-width: 80%;
  }
</style>
