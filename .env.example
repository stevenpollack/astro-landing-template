# The single secrets file. Copy to `.env`, fill in, then run `bun run bootstrap`
# (add `--setup-gh` to also configure GitHub Actions). `.dev.vars` for local dev is
# generated from this — you never edit it directly.
#
# Public config (your domain + the Turnstile sitekey) lives in `src/config.ts`,
# NOT here. The Turnstile *secret* isn't here either — bootstrap creates the widget
# and pushes its secret straight to the Worker (it never needs to touch this file).
#
# Prerequisites you create by hand (no provisioning API exists for either):
#   - a Cloudflare account + API token (scopes below), and
#   - a Fastmail account + API token (Email + Email Submission scopes).

# Encrypts secrets in the local .alchemy/ state. Choose a strong value and keep it
# (the committed state only decrypts with the same password).
ALCHEMY_PASSWORD=""

# Cloudflare. Token scopes: Workers Scripts:Edit, Turnstile:Edit, Workers Routes:Edit,
# and — only if you set a custom domain in src/config.ts — Zone:Read + DNS:Edit.
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ACCOUNT_ID=""

# Contact form (Fastmail JMAP). Pushed to the Worker by bootstrap; they persist.
FASTMAIL_API_TOKEN=""         # Fastmail token: Email + Email Submission scopes
MAIL_FROM="you@acme.example"  # verified Fastmail address to send AS
MAIL_TO="you@acme.example"    # where leads are delivered (can equal MAIL_FROM)

# Only for `bun run bootstrap --setup-gh` (a GitHub token with Actions secrets admin).
GITHUB_TOKEN=""
