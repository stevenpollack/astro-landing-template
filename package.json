{
	"name": "astro-landing-template",
	"type": "module",
	"version": "0.0.1",
	"engines": {
		"node": ">=22.12.0"
	},
	"scripts": {
		"dev": "bun scripts/dev-vars.ts && astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"check": "astro check",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"format": "biome format --write",
		"e2e": "playwright test",
		"e2e:preview": "bun scripts/preview-smoke.ts",
		"verify": "bun run lint && bun run check && bun run build",
		"bootstrap": "bun scripts/bootstrap.ts",
		"deploy": "bun run build && wrangler deploy",
		"destroy": "bun scripts/destroy.ts",
		"astro": "astro",
		"generate-types": "wrangler types",
		"prepare": "lefthook install || true"
	},
	"dependencies": {
		"@astrojs/cloudflare": "^14.0.0",
		"astro": "^7.0.0",
		"wrangler": "^4.103.0"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@axe-core/playwright": "^4.11.3",
		"@biomejs/biome": "^2.5.0",
		"@playwright/test": "^1.61.0",
		"@types/node": "^26.0.0",
		"alchemy": "^0.93.12",
		"lefthook": "^2.1.9",
		"typescript": "^6.0.3"
	}
}
